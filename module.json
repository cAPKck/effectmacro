{
  "id": "effectmacro",
  "title": "Effect Macro",
  "description": "A module that allows users to embed macros directly into effects.",
  "version": "AUTOMATIC",

  "authors": [
    {
      "name": "Zhell",
      "url": "https://git.gay/Zhell",
      "discord": "zhell9201"
    }
  ],
  "compatibility": {
    "minimum": "14.361",
    "verified": "14"
  },
  "esmodules": [
    "main.mjs"
  ],
  "styles": [
    {
      "src": "main.css",
      "layer": "module"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    },
    {
      "lang": "pt-BR",
      "name": "Português (Brasil)",
      "path": "lang/pt-BR.json",
      "flags": {}
    }
  ],
  "url": "https://git.gay/Zhell/effectmacro",
  "manifest": "https://git.gay/Zhell/effectmacro/releases/download/latest/module.json",
  "download": "AUTOMATIC",
  "license": "https://git.gay/Zhell/effectmacro/raw/branch/main/LICENSE",

  "changelog": "https://git.gay/Zhell/effectmacro/releases",
  "flags": {
    "hotReload": {
      "extensions": [
        "css",
        "hbs",
        "json"
      ],
      "paths": [
        "lang",
        "styles",
        "templates"
      ]
    }
  }
}
